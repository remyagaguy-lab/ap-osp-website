<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Redirection de http vers https et de non-www vers www
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^ap-osp\.org [NC]
  RewriteRule ^(.*)$ https://www.ap-osp.org/$1 [L,R=301]

  # Forcer le trailing slash (important pour Next.js export statique)
  # Sauf pour les fichiers avec extension
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ $1/ [L,R=301]

  # Next.js Static Export routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)/$ $1.html [L]

  # Fallback vers index.html pour les erreurs 404
  ErrorDocument 404 /404.html
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
